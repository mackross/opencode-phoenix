#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CMD="${1:-}"
[[ -n "$CMD" ]] || { echo "usage: opencode-phoenix <install|update|check> [--target PATH] [--force]"; exit 2; }
shift || true

TARGET="${OPENCODE_PHOENIX_TARGET:-$PWD}"
REPO="${OPENCODE_PHOENIX_REPO:-https://github.com/mackross/opencode-phoenix.git}"
REF="${OPENCODE_PHOENIX_REF:-main}"
DST="${OPENCODE_PHOENIX_DST:-/tmp/opencode-phoenix}"
FORCE=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --target) TARGET="$2"; shift 2 ;;
    --force) FORCE=1; shift ;;
    *) echo "unknown arg: $1"; exit 2 ;;
  esac
done

TARGET="${TARGET/#\~/$HOME}"
DST="${DST/#\~/$HOME}"

PULL_TASK="$TARGET/lib/mix/tasks/opencode/phoenix/pull.ex"
TMP_SRC="$ROOT/mix_tasks/opencode/phoenix/pull_tmp.ex"
TMP_DST="$TARGET/lib/mix/tasks/opencode/phoenix/pull_tmp.ex"

run_pull() {
  (
    cd "$TARGET"
    mix opencode.phoenix.pull --repo "$REPO" --ref "$REF" --dst "$DST" "$@"
  )
}

bootstrap_pull_task() {
  mkdir -p "$(dirname "$TMP_DST")"
  cp "$TMP_SRC" "$TMP_DST"

  (
    cd "$TARGET"
    mix opencode.phoenix.pull.tmp --repo "$REPO" --ref "$REF" --dst "$DST"
  )

  rm -f "$TMP_DST"
}

ensure_pull_task() {
  [[ -f "$PULL_TASK" ]] || bootstrap_pull_task
}

case "$CMD" in
  install)
    ensure_pull_task
    run_pull --force
    ;;
  update)
    ensure_pull_task
    if [[ "$FORCE" -eq 1 ]]; then run_pull --force; else run_pull; fi
    ;;
  check)
    ensure_pull_task
    run_pull --check
    ;;
  *) echo "unknown command: $CMD"; exit 2 ;;
esac
